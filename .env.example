# Postgres (AWS RDS)
DB_HOST=
DB_USER=postgres
DB_PASS=
DB_NAME=postgres
DB_PORT=5432

# Prisma connection string. Schema is namespaced to `newhome`.
# Format: postgresql://USER:PASS@HOST:PORT/DB?schema=newhome&sslmode=require
DATABASE_URL=

# Cron auth secret. Vercel auto-injects "Authorization: Bearer $CRON_SECRET"
# when this is set in the project's environment.
CRON_SECRET=

# Telegram bot (optional). Leave empty to disable notifications.
# 1) Talk to @BotFather on Telegram → /newbot → get token
# 2) Talk to @userinfobot → get your numeric chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
